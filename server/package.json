{
  "name": "file-browser-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Fastify backend for Local Network File Browser",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/"
  },
  "dependencies": {
    "@fastify/auth": "^4.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.0.0",
    "@fastify/static": "^6.12.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.0",
    "bcrypt": "^5.1.1",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "fluent-ffmpeg": "^2.1.2",
    "node-cache": "^5.1.2",
    "open": "^10.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcrypt": "^5.0.2",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.14.12",
    "@types/node-cache": "^4.2.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}