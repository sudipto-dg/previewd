{
    "name": "file-browser-server",
    "version": "1.0.0",
    "type": "module",
    "description": "Fastify backend for Local Network File Browser",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "biome check src/",
        "format": "biome format --write src/",
        "format:check": "biome format src/"
    },
    "dependencies": {
        "@fastify/auth": "^5.0.4",
        "@fastify/cors": "^11.2.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/multipart": "^9.4.0",
        "@fastify/static": "^9.0.0",
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@ffprobe-installer/ffprobe": "^2.1.2",
        "bcrypt": "^6.0.0",
        "fastify": "^5.7.4",
        "fastify-plugin": "^5.1.0",
        "fluent-ffmpeg": "^2.1.3",
        "node-cache": "^5.1.2",
        "open": "^11.0.0",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/node": "^25.3.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
